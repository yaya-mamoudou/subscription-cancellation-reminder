{
  "entities": {
    "Subscription": {
      "title": "Subscription",
      "description": "A subscription or trial to monitor.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "The name of the service." },
        "endDate": { "type": "string", "format": "date", "description": "The date the trial or subscription ends." },
        "reminderDays": { "type": "integer", "description": "Days before end date to send a reminder." },
        "cancelUrl": { "type": "string", "format": "uri", "description": "Optional URL to cancel the subscription." },
        "color": { "type": "string", "description": "Hex color code for the UI accent." },
        "userId": { "type": "string", "description": "The UID of the owner." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the record was created." }
      },
      "required": ["name", "endDate", "reminderDays", "color", "userId", "createdAt"]
    }
  },
  "firestore": {
    "users/{userId}/subscriptions/{subscriptionId}": {
      "schema": "Subscription",
      "description": "User-specific subscriptions."
    }
  }
}
